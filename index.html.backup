                                        items: ['TFT_eSPI', 'LVGL', 'u8g2', 'Adafruit-GFX-Library', 'NeoPixelBus', 'FastLED', 'M5Unified', 'ssd1306', 'ILI9341'],
                                        color: '#8b5cf6'
                                    },
                                    {
                                        title: '物联网与云服务',
                                        icon: '☁️',
                                        items: ['ArduinoJson', 'Blinker', 'Firebase-ESP-Client', 'HomeKit-ESP32', 'ESPresense', 'Telegram-Bot', 'ESP-RainMaker', 'Blynk', 'PubSubClient', 'Courier'],
                                        color: '#10b981'
                                    },
                                    {
                                        title: '外设驱动',
                                        icon: '🔌',
                                        items: ['Adafruit-PWM-Servo-Driver', 'ESP32Servo', 'AccelStepper', 'MFRC522', 'IRremote', 'Rtc', 'SD', 'SPI', 'Wire'],
                                        color: '#ef4444'
                                    },
                                    {
