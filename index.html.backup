                                        icon: '📁',
                                        items: ['SPIFFS', 'LITTLEFS', 'FATFS', 'SdFat', 'VFS', 'ESP-UFFS', 'FSBrowser'],
                                        color: '#06b6d4'
                                    },
                                    {
                                        title: '加密与安全',
                                        icon: '🔐',
                                        items: ['mbedTLS', 'esp-cryptoauthlib', 'AES', 'SHA', 'ArduinoJWT', 'Adafruit_QRCode'],
                                        color: '#8b5cf6'
                                    },
                                    {
                                        title: '实用工具',
                                        icon: '🛠️',
                                        items: ['Time', 'NTPClient', 'ezTime', 'TaskScheduler', 'SimpleTimer', 'Preferences', 'Kalman', 'Madgwick', 'ArduinoTrace'],
