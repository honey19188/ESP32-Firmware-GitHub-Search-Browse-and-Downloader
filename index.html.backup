                                        icon: '🌿',
                                        items: ['土壤湿度', 'Plantmonitor', 'TDS测量'],
                                        color: '#10b981'
                                    },
                                    {
                                        title: '🚀 特殊功能传感器',
                                        icon: '🚀',
