                                        title: '应用解决方案',
                                        icon: '📦',
                                        items: ['ESP-IDF', 'MicroPython', 'ESPHome', 'Tasmota', 'ESP-WHO', 'ESP-CSI', 'PlatformIO', 'OpenMV'],
                                        color: '#10b981'
                                    }
                                ].map((category, idx) => (
                                    <div
                                        key={idx}
                                        style={{
                                            background: 'var(--bg-secondary)',
                                            border: '1px solid var(--border)',
                                            borderRadius: '12px',
                                            padding: '1.25rem'
                                        }}
                                    >
                                        <h3 style={{ fontSize: '1rem', marginBottom: '0.75rem', display: 'flex', alignItems: 'center', gap: '0.5rem' }}>
                                            <span>{category.icon}</span>
                                            {category.title}
                                        </h3>
                                        <div style={{ display: 'flex', flexWrap: 'wrap', gap: '0.5rem' }}>
                                            {category.items.map((item, i) => (
                                                <span
                                                    key={i}
                                                    className="history-tag"
                                                    onClick={() => handleHistoryClick(item)}
                                                    style={{
                                                        borderColor: category.color,
                                                        background: 'transparent'
                                                    }}
                                                    title={`搜索 ${item}`}
                                                >
                                                    <span className="en-name" style={{ color: category.color }}>{item}</span>
                                                    <span className="cn-name">{getChineseName(item)}</span>
                                                </span>
                                            ))}
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>
                    )}

                    {loading && (
                        <div className="loading">
                            <div className="spinner"></div>
                            <span>{loadingText}</span>
                        </div>
                    )}

                    {!loading && repos.length > 0 && (
                        <div style={{ marginTop: '2rem' }}>
                            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '1rem' }}>
                                <span style={{ color: 'var(--text-secondary)' }}>找到 {repos.length} 个仓库</span>
                                <button
                                    onClick={translateDescriptions}
                                    disabled={translating}
                                    className="nav-btn"
                                    style={{ display: 'flex', alignItems: 'center', gap: '0.5rem' }}
                                >
                                    {translating ? (
                                        <>翻译中 {transProgress}%</>
                                    ) : (
                                        <>
                                            <Icons.Translate />
                                            {translateEnabled ? '显示原文' : '翻译描述'}
                                        </>
                                    )}
                                </button>
                            </div>
                            {translating && (
                                <div className="progress-container" style={{ marginBottom: '1rem' }}>
                                    <div className="progress-bar">
                                        <div className="progress-fill" style={{ width: `${transProgress}%` }}></div>
                                    </div>
                                </div>
                            )}
                        <div className="repo-grid">
                            {(filterReleasesOnly ? repos.filter(r => r.hasReleases) : repos).map((repo, index) => (
                                <div
                                    key={repo.id}
                                    className="repo-card"
                                    style={{ animationDelay: `${index * 50}ms` }}
                                    onClick={() => (repo.hasReleases || repo.hasSourceCode) && handleRepoClick(repo)}
                                >
                                    <div className="repo-header">
                                        <div className="repo-icon">
                                            <Icons.Chip />
                                        </div>
                                        <div className="repo-info">
                                            <div className="repo-name">{repo.full_name}</div>
                                            <div className="repo-stars">
                                                <Icons.Star /> {repo.stargazers_count.toLocaleString()}
                                            </div>
                                        </div>
                                    </div>
                                    {/* 状态标签 */}
                                    <div style={{
                                        display: 'flex',
                                        alignItems: 'center',
                                        gap: '0.5rem',
                                        marginBottom: '0.75rem',
                                        flexWrap: 'wrap'
                                    }}>
                                        {repo.latest_release && repo.hasReleases && (
                                            <div style={{
                                                display: 'flex',
                                                alignItems: 'center',
                                                gap: '0.5rem',
                                                padding: '0.375rem 0.5rem',
                                                background: 'var(--bg-card)',
                                                borderRadius: '8px',
                                                fontSize: '0.8rem'
                                            }}>
                                                <span style={{
                                                    background: 'var(--success)',
                                                    color: '#000',
                                                    padding: '0.125rem 0.5rem',
                                                    borderRadius: '4px',
                                                    fontWeight: 600
                                                }}>
                                                    📦
                                                </span>
                                                <span className="mono" style={{ color: 'var(--accent)', fontWeight: 600 }}>
                                                    {repo.latest_release.tag_name}
                                                </span>
                                                <span style={{ color: 'var(--text-secondary)' }}>
                                                    {new Date(repo.latest_release.published_at).toLocaleDateString('zh-CN')}
                                                </span>
                                            </div>
                                        )}
                                        {repo.hasSourceCode && !repo.hasReleases && (
                                            <div style={{
                                                display: 'flex',
                                                alignItems: 'center',
                                                gap: '0.5rem',
                                                padding: '0.375rem 0.5rem',
                                                background: 'var(--bg-secondary)',
                                                borderRadius: '8px',
                                                fontSize: '0.8rem'
                                            }}>
                                                <span style={{
                                                    background: 'var(--accent)',
                                                    color: '#fff',
                                                    padding: '0.125rem 0.5rem',
                                                    borderRadius: '4px',
                                                    fontWeight: 600
                                                }}>
                                                    💾
                                                </span>
                                                <span style={{ color: 'var(--text-secondary)' }}>
                                                    有源代码
                                                </span>
                                            </div>
                                        )}
                                        {!repo.hasReleases && !repo.hasSourceCode && (
                                            <div style={{
                                                display: 'flex',
                                                alignItems: 'center',
                                                gap: '0.5rem',
                                                padding: '0.375rem 0.5rem',
                                                background: 'var(--bg-secondary)',
                                                borderRadius: '8px',
                                                fontSize: '0.8rem'
                                            }}>
                                                <span style={{
                                                    background: 'var(--warning)',
                                                    color: '#000',
                                                    padding: '0.125rem 0.5rem',
                                                    borderRadius: '4px',
                                                    fontWeight: 600
                                                }}>
                                                    !
                                                </span>
                                                <span style={{ color: 'var(--text-secondary)' }}>
                                                    无发布无代码
                                                </span>
                                            </div>
                                        )}
                                    </div>
                                    <p className="repo-desc">
                                        {translateEnabled && translatedDescs[repo.id]
                                            ? translatedDescs[repo.id]
                                            : (repo.description || '暂无描述')}
                                    </p>
                                    <a
                                        href={repo.html_url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        className="repo-link"
                                        onClick={(e) => e.stopPropagation()}
                                    >
                                        <Icons.ExternalLink /> {repo.html_url}
                                    </a>
                                </div>
                            ))}
                        </div>
                        </div>
                    )}

                    {!loading && repos.length === 0 && (
                        <div className="empty-state">
                            <p>未找到相关仓库</p>
                            <p style={{ fontSize: '0.875rem', marginTop: '0.5rem', color: 'var(--text-secondary)' }}>
                                尝试使用不同的关键词搜索
                            </p>
                        </div>
                    )}
                </div>
            );
        }

        // Detail Page
        function DetailPage() {
            const { selectedRepo, goBack, setToast } = useContext(AppContext);
            const [releases, setReleases] = useState([]);
            const [loading, setLoading] = useState(true);
            const [expandedRelease, setExpandedRelease] = useState(null);

            useEffect(() => {
                if (selectedRepo) {
                    fetchReleases();
                } else {
                    // 如果没有选中仓库，跳回上一页
                    goBack();
                }
            }, [selectedRepo, goBack]);

            const fetchReleases = async () => {
                if (!selectedRepo) return;
                setLoading(true);
                try {
                    const [owner, repo] = selectedRepo.full_name.split('/');
                    const res = await fetch(`${GITHUB_API}/repos/${owner}/${repo}/releases`);
                    if (!res.ok) {
                        throw new Error(`HTTP error! status: ${res.status}`);
                    }
                    const data = await res.json();
                    setReleases(Array.isArray(data) ? data : []);
                } catch (err) {
                    console.error('Failed to fetch releases:', err);
                    setToast('获取版本失败，请检查网络', 'error');
                    setReleases([]);
                }
                setLoading(false);
            };

            const handleDownload = (url, name) => {
                // Record download
                const downloads = JSON.parse(localStorage.getItem('esp32_downloads') || '[]');
                downloads.unshift({
                    name: name,
                    size: 0,
                    url: url,
                    repo: selectedRepo.full_name,
                    downloadedAt: new Date().toISOString()
                });
                localStorage.setItem('esp32_downloads', JSON.stringify(downloads.slice(0, 100)));

                // Trigger download
                const link = document.createElement('a');
                link.href = url;
                link.download = name;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);

                setToast(`已开始下载: ${name}`, 'success');
            };

            const formatSize = (bytes) => {
                if (bytes < 1024) return bytes + ' B';
                if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
                return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
            };

            const formatDate = (dateStr) => {
                return new Date(dateStr).toLocaleDateString('zh-CN');
            };

            return (
                <div>
                    <div className="detail-header">
                        <button className="back-btn" onClick={goBack}>
                            <Icons.ArrowLeft /> 返回上一页
                        </button>

                        <h1 className="detail-title">{selectedRepo?.full_name}</h1>
                        <p className="detail-desc">{selectedRepo?.description || '暂无描述'}</p>

                        <div className="detail-meta">
                            <div className="meta-item">
                                <Icons.Star /> {selectedRepo?.stargazers_count.toLocaleString()} 星标
                            </div>
                            <div className="meta-item">
                                <a href={selectedRepo?.html_url} target="_blank" rel="noopener noreferrer">
                                    <Icons.ExternalLink /> 在 GitHub 查看
                                </a>
                            </div>
                            {/* 源代码下载 */}
                            {selectedRepo?.default_branch && (
                                <div className="meta-item">
                                    <a href={`${selectedRepo.html_url}/archive/refs/heads/${selectedRepo.default_branch}.zip`} onClick={(e) => {
                                        e.stopPropagation();
                                        handleDownload(
                                            `${selectedRepo.html_url}/archive/refs/heads/${selectedRepo.default_branch}.zip`,
                                            `${selectedRepo.name}-${selectedRepo.default_branch}.zip`
                                        );
                                    }} className="download-btn" style={{ display: 'inline-flex', alignItems: 'center', gap: '0.5rem', textDecoration: 'none', color: 'var(--text-primary)', background: 'var(--accent)', padding: '0.5rem 1rem', borderRadius: '8px' }}>
                                        <Icons.Download /> 下载源代码
                                    </a>
                                </div>
                            )}
                        </div>
                    </div>

                    <h2 className="section-title">
                        <Icons.Download /> 版本列表 ({releases.length})
                    </h2>

                    {loading && (
                        <div className="loading">
                            <div className="spinner"></div>
                            <span>加载中...</span>
                        </div>
                    )}

                    {!loading && releases.length === 0 && (
                        <div className="empty-state">
                            <p>暂无版本发布</p>
                            <p style={{ fontSize: '0.875rem', marginTop: '0.5rem', color: 'var(--text-secondary)' }}>
                                您可以下载源代码
                            </p>
                        </div>
                    )}

                    <div className="releases-list">
                        {releases.map((release) => (
                            <div key={release.id} className="release-item">
                                <div
                                    className="release-header"
                                    onClick={() => setExpandedRelease(expandedRelease === release.tag_name ? null : release.tag_name)}
                                >
                                    <div className="release-info">
                                        <span className="release-tag">{release.tag_name}</span>
                                        <span className="release-date">
                                            {formatDate(release.published_at)}
                                        </span>
                                        {release.prerelease && (
                                            <span className="release-badge">预发布</span>
                                        )}
                                    </div>
                                    <div className={`release-toggle ${expandedRelease === release.tag_name ? 'expanded' : ''}`}>
                                        <Icons.ChevronDown />
                                    </div>
                                </div>

                                <div className={`release-content ${expandedRelease === release.tag_name ? 'expanded' : ''}`}>
                                    {release.name && (
                                        <p style={{ color: 'var(--text-secondary)', marginBottom: '0.5rem' }}>
                                            {release.name}
                                        </p>
                                    )}

                                    <div className="asset-list">
                                        {release.assets && release.assets.length > 0 ? (
                                            release.assets.map((asset) => (
                                                <div key={asset.id} className="asset-item">
                                                    <div className="asset-info">
                                                        <div className="asset-icon">
                                                            <Icons.File />
                                                        </div>
                                                        <div>
                                                            <div className="asset-name">{asset.name}</div>
                                                            <div className="asset-size">{formatSize(asset.size)}</div>
                                                        </div>
                                                    </div>
                                                    <button
                                                        className="download-btn"
                                                        onClick={() => handleDownload(asset.browser_download_url, asset.name)}
                                                    >
                                                        <Icons.Download /> 下载
                                                    </button>
                                                </div>
                                            ))
                                        ) : (
                                            <p style={{ color: 'var(--text-secondary)', padding: '0.75rem' }}>
                                                此版本暂无固件文件
                                            </p>
                                        )}

                                        {/* 源代码下载链接 */}
                                        <div style={{ marginTop: '0.75rem', paddingTop: '0.75rem', borderTop: '1px solid var(--border)' }}>
                                                <p style={{ color: 'var(--text-secondary)', fontSize: '0.875rem', marginBottom: '0.5rem' }}>
                                                    源代码：
                                            </p>
                                                <div className="asset-list">
                                                    <div className="asset-item">
                                                        <div className="asset-info">
                                                            <div className="asset-icon">
                                                                <Icons.File />
                                                            </div>
                                                            <div>
                                                                <div className="asset-name">{release.tag_name}.zip</div>
                                                            </div>
                                                        </div>
                                                        <button
                                                            className="download-btn"
                                                            onClick={() => handleDownload(release.zipball_url, `${release.tag_name}.zip`)}
                                                        >
                                                            <Icons.Download /> ZIP
                                                        </button>
                                                    </div>
                                                    <div className="asset-item">
                                                        <div className="asset-info">
                                                            <div className="asset-icon">
                                                                <Icons.File />
                                                            </div>
                                                            <div>
                                                                <div className="asset-name">{release.tag_name}.tar.gz</div>
                                                            </div>
                                                        </div>
                                                        <button
                                                            className="download-btn"
                                                            onClick={() => handleDownload(release.tarball_url, `${release.tag_name}.tar.gz`)}
                                                        >
                                                            <Icons.Download /> TAR.GZ
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            );
        }

        // Downloads Page
        function DownloadsPage() {
            const { goBack, setToast } = useContext(AppContext);
            const [downloads, setDownloads] = useState([]);

            useEffect(() => {
                loadDownloads();
            }, []);

            const loadDownloads = () => {
                const data = JSON.parse(localStorage.getItem('esp32_downloads') || '[]');
                setDownloads(data);
            };

            const handleDelete = (index) => {
                const newDownloads = downloads.filter((_, i) => i !== index);
                localStorage.setItem('esp32_downloads', JSON.stringify(newDownloads));
                setDownloads(newDownloads);
                setToast('已删除记录', 'success');
            };

            const handleClear = () => {
                localStorage.removeItem('esp32_downloads');
                setDownloads([]);
                setToast('已清空记录', 'success');
            };

            const handleReDownload = (item) => {
                const link = document.createElement('a');
                link.href = item.url;
                link.download = item.name;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                setToast(`已开始下载: ${item.name}`, 'success');
            };

            const formatSize = (bytes) => {
                if (bytes < 1024) return bytes + ' B';
                if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
                return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
            };

            const formatDate = (dateStr) => {
                return new Date(dateStr).toLocaleDateString('zh-CN') + ' ' +
                       new Date(dateStr).toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
            };

            return (
                <div>
                    <div className="downloads-header">
                        <button className="back-btn" onClick={goBack}>
                            <Icons.ArrowLeft /> 返回上一页
                        </button>
                        <h1 className="downloads-title">下载管理</h1>
                        {downloads.length > 0 && (
                            <button className="clear-btn" onClick={handleClear}>
                                清空记录
                            </button>
                        )}
                    </div>

                    {downloads.length === 0 && (
                        <div className="empty-state">
                            <Icons.Folder />
                            <p style={{ marginTop: '1rem' }}>暂无下载记录</p>
                        </div>
                    )}

                    {downloads.length > 0 && (
                        <div className="downloads-list">
                            {downloads.map((item, index) => (
                                <div key={index} className="download-item">
                                    <div className="download-icon">
                                        <Icons.Check />
                                    </div>
                                    <div className="download-info">
                                        <div className="download-name">{item.name}</div>
                                        <div className="download-meta">
                                            <span>{formatSize(item.size)}</span>
                                            <span>•</span>
                                            <span>{item.repo}</span>
                                            <span>•</span>
                                            <span>{formatDate(item.downloadedAt)}</span>
                                        </div>
                                    </div>
                                    <div className="download-actions">
                                        <button
                                            className="action-btn"
                                            onClick={() => handleReDownload(item)}
                                            title="重新下载"
                                        >
                                            <Icons.Download />
                                        </button>
                                        <button
                                            className="action-btn delete"
                                            onClick={() => handleDelete(index)}
                                            title="删除记录"
                                        >
                                            <Icons.Trash />
                                        </button>
                                    </div>
                                </div>
                            ))}
                        </div>
                    )}
                </div>
            );
        }

        // Main App
        function App() {
            const [currentPage, setCurrentPage] = useState('search');
            const [pageHistory, setPageHistory] = useState(['search']);
            const [selectedRepo, setSelectedRepo] = useState(null);
            const [toast, setToast] = useState(null);
            const [searchHistory, setSearchHistory] = useState([]);

            useEffect(() => {
                // Load search history
                const history = JSON.parse(localStorage.getItem('esp32_search_history') || '[]');
                setSearchHistory(history);
            }, []);

            const handleToastClose = useCallback(() => {
                setToast(null);
            }, []);

            const navigateToPage = useCallback((page, repo = null) => {
                setPageHistory(prev => [...prev, page]);
                if (repo) {
                    setSelectedRepo(repo);
                }
                setCurrentPage(page);
            }, []);

            const goBack = useCallback(() => {
                if (pageHistory.length > 1) {
                    const newHistory = pageHistory.slice(0, -1);
                    setPageHistory(newHistory);
                    const previousPage = newHistory[newHistory.length - 1];
                    setCurrentPage(previousPage);
                } else {
                    setCurrentPage('search');
                    setPageHistory(['search']);
                }
            }, [pageHistory]);

            return (
                <AppContext.Provider value={{
                    currentPage,
                    setCurrentPage: navigateToPage,
                    goBack,
                    selectedRepo,
                    setSelectedRepo,
                    toast,
                    setToast,
                    searchHistory,
                    setSearchHistory
                }}>
                    <div className="app">
                        <Header />
                        <main className="main">
                            {currentPage === 'search' && <SearchPage />}
                            {currentPage === 'detail' && <DetailPage />}
                            {currentPage === 'downloads' && <DownloadsPage />}
                        </main>
                        {toast && (
                            <Toast
                                message={toast.message}
                                type={toast.type}
                                onClose={handleToastClose}
                            />
                        )}
                    </div>
                </AppContext.Provider>
            );
        }

        // Render
        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
