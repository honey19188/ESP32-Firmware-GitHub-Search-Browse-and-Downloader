                                        title: '⚡ 惯性测量IMU',
                                        icon: '⚡',
                                        items: ['MPU9250', 'MPU9255', 'ICM20948', 'BNO055', 'BNO085', 'BNO086'],
                                        color: '#06b6d4'
                                    },
                                    {
                                        title: '✋ 交互与状态感知',
                                        icon: '✋',
                                        items: ['APDS9960', 'TCS34725', 'VCNL4010'],
                                        color: '#3b82f6'
                                    },
                                    {
                                        title: '🧪 气体与物质检测',
                                        icon: '🧪',
                                        items: ['MQ-2', 'MQ-5', 'MQ-7', 'MQ-135', 'ZMOD4410', 'Senseair S8'],
                                        color: '#ef4444'
                                    },
                                    {
